---
import type { PostData } from "@utils/post.type";

interface Props {
  id: string;
  post: PostData;
}

const { post, id }: Props = Astro.props;
const { title, description, date, tags, suggestedPosts, img } = post;
---

<a class=`postCard` href=`${import.meta.env.BASE_URL}/blog/post/${id}`>
  <div class="border">
    <!-- Tags -->
    {tags && tags.length > 0 && <div id="tagList">{tags.join(" ")}</div>}
    <strong id="title">{title}</strong>
    <p id="description">{description}</p>
  </div>
</a>

<style>
  .postCard {
    background-color: var(--base);
    max-width: var(--max-width);
    min-width: var(--min-width);

    display: block;
    padding: 10px;
    border-radius: 15px;
    margin-bottom: 20px;
    margin-inline: auto;

    cursor: pointer;
    text-decoration: none;
    transition: transform 0.5s;
    overflow: hidden;
  }
  .postCard * {
    font-family: monospace;
  }
  .postCard:hover {
    transform: translateY(-15px);
  }

  .border {
    min-height: 70px;
    border: 2px solid var(--secondary);
    border-radius: 10px;
    padding: 5px 10px 10px;
    position: relative;
  }

  #tagList,
  #title {
    color: var(--secondary);
    background-color: var(--base);
    font-weight: bold;
  }

  #tagList {
    padding: 0 5px;
    z-index: 1;
    position: absolute;
    top: -10px;
    right: 20px;
  }

  #title {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  #description {
    margin: 0;
    color: var(--text);
  }
</style>
