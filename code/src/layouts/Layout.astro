---
import GlobalStyles from "src/GlobalStyles.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import Background from "./Background.astro";

interface Props {
  title: string;
  description: string;
  showLink?: boolean;
}

const { title, description, showLink }: Props = Astro.props;
const parsedTitle = `${title}${!showLink ? "" : " - ElelisPage"}`;
const image = `${import.meta.env.BASE_URL}/favicon.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="light dark" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="all" />
    <meta name="Content-Language" content="es-ES" />
    <meta name="revisit-after" content="1 days" />
    <link rel="icon" type="image/svg+xml" href={image} />

    <meta itemprop="name" content={`${parsedTitle}`} />
    <meta itemprop="description" content={description} />
    <meta itemprop="image" content={image} />

    <title>{parsedTitle}</title>
    <GlobalStyles />
  </head>

  <body>
    <Header />
    <Background />
    <div id="index">
      <slot />

      <Footer />
    </div>
  </body>
</html>

<style>
  #index {
    position: absolute;
    z-index: 1;
    width: 100%;
    height: 100vh;
    min-height: 100dvh;

    scroll-behavior: smooth;
    overflow: auto;
  }
</style>
