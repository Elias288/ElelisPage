---
import ListPosts from "@components/ListPosts/index.astro";
import Layout from "@layouts/Layout.astro";
import SearchComponent from "@components/SearchComponent.astro";
---

<Layout
  title="Blog"
  showLink={true}
  description="Blog donde publicar mis ideas."
>
  <section id="blog">
    <div class="blogMenu">
      <h2>Blog</h2>
      <SearchComponent />
    </div>

    <ListPosts />
  </section>
</Layout>

<style>
  @media screen and (min-width: 677px) {
    .blogMenu {
      justify-content: space-between;
      display: flex;

      gap: 10px;
    }
  }
</style>
