---
import type { GetStaticPaths } from "astro";
import Layout from "@layouts/Layout.astro";
import { getCollection, getEntry } from "astro:content";
import { render } from "astro:content";
import arrow_back from "@assets/arrow_back.svg?raw";

import "./_mdStyles.css";

export const getStaticPaths = (async () => {
  const posts = await getCollection("posts");

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post, allPosts: posts },
  }));
}) satisfies GetStaticPaths;

const { post, allPosts } = Astro.props;
const { data } = post;

const suggestedPosts = post.data.suggestedPost
  ? await Promise.all(
      post.data.suggestedPost.map((id) => getEntry("posts", id)),
    )
  : [];

const { Content } = await render(post);
---

<Layout title={data.title} description={data.description} showLink={true}>
  <section class="post">
    <!-- Go Back -->
    <a href={`${import.meta.env.BASE_URL}/blog`}>
      <Fragment set:html={arrow_back} />
    </a>

    <div class="content__container">
      <!-- Date -->
      <small class="date">{data.date.toISOString().split("T")[0]}</small>

      <!-- Tags -->
      {
        data.tags && data.tags.length > 0 && (
          <div class="tagList">
            {data.tags.map((tag, index) => (
              <>
                <span>
                  <a href="#">{tag}</a>
                </span>
                {data.tags && index < data.tags?.length - 1 && <span>|</span>}
              </>
            ))}
          </div>
        )
      }

      <!-- Title -->
      <h2 class="title">{data.title}</h2>

      <!-- Post Description -->
      <p class="description">{data.description}</p>

      <!-- Content -->
      <div id="content"><Content /></div>

      {
        suggestedPosts.length > 0 && (
          <div id="suggestedPost">
            <h2>Posts sugeridos</h2>
            {suggestedPosts.map((s) => (
              <div class="card">
                {s && (
                  <a
                    class="cardLink"
                    href={`${import.meta.env.BASE_URL}/blog/post/${s.id}`}
                  >
                    <strong class="cardTitle">{s.data.title}</strong>
                    <p class="cardDescription">{s.data.description}</p>
                  </a>
                )}
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .tagList {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
  }
  .tagList * {
    color: var(--text);
    opacity: 0.8;
  }
  .tagList a {
    text-decoration: none;
    cursor: pointer;
    font-weight: bold;
  }
  .tagList a:hover {
    opacity: 0.5;
  }

  .date {
    opacity: 0.6;
    float: right;
  }

  .title {
    font-size: 3rem;
    text-wrap: balance;
  }
  .description {
    opacity: 0.6;
  }

  :global(.post svg) {
    width: 30px;
    height: 30px;
    color: var(--secondary);

    cursor: pointer;
  }
  :global(.post svg:hover) {
    opacity: 0.6;
  }

  .content__container {
    max-width: 700px;
    margin-inline: auto;
  }

  #suggestedPost {
    margin-top: 5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--primary);
  }
  #suggestedPost .card:hover > .cardLink {
    transform: translateY(-15px);
  }
  #suggestedPost .card .cardLink {
    transition: transform 0.5s;
    display: block;
    background-color: var(--base);
    border-radius: 15px;
    cursor: pointer;
    border: 2px solid var(--secondary);
    max-width: var(--max-width);
    min-width: var(--min-width);
    margin-bottom: 20px;
    margin-inline: auto;
    /*margin-right: 10px;*/
    padding: 10px;
    text-decoration: none;
  }
  #suggestedPost .cardTitle {
    font-size: 1.5rem;
    color: var(--secondary);
  }
  #suggestedPost .cardDescription {
    color: var(--text);
  }
</style>
