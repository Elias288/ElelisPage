---
import Layout from "@layouts/Layout.astro";
import SobreMi from "@components/SobreMi.astro";
import Habilidades from "@components/Habilidades.astro";
import Proyectos from "@components/Proyectos/Index.astro";
import Experiencia from "@components/Experiencia.astro";
import Educacion from "@components/Educacion.astro";
import SocialButtonComponent from "@components/SocialButtonComponent.astro";

import github_logo from "@assets/github-logo.svg?raw";
import gitlab_logo from "@assets/gitlab-logo.svg?raw";
import linkedin_logo from "@assets/linkedin.svg?raw";
import gmail from "@assets/gmail.svg?raw";
---

<Layout
  title="ElelisPage - Portafolio"
  description="Hola, soy Elías Bianchi. Desarrollador informático, consultor en Frame banking. Diseño y construyo aplicaciones modernas que combinan eficiencia, escalabilidad y una gran experiencia de usuario."
>
  <section id="inicio">
    <div class="inicio__container">
      <h1>Hola, soy <span class="name">Elías Bianchi</span></h1>
      <p>Desarrollador informático, consultor en Frame banking.</p>
      <p>
        Diseño y construyo aplicaciones modernas que combinan eficiencia,
        escalabilidad y una gran experiencia de usuario.
      </p>
      
      <ul class="social-links">
        <li>
          <SocialButtonComponent url="https://github.com/Elias288" label="Github" title="Github" icon={github_logo} />
        </li>
        <li>
          <SocialButtonComponent url="https://gitlab.com/bianchi.elias" title="GitLab" label="GitLab" icon={gitlab_logo} />
        </li>
        <li>
          <SocialButtonComponent disable url="https://www.linkedin.com/in/elias-bianchi-3a5012183/" title="Linkedin" label="Linkedin" icon={linkedin_logo} />
        </li>
        <li>
          <SocialButtonComponent url="mailto:bianchi.elias@gmail.com" label="bianchi.elias@gmail.com" icon={gmail} title="Correo" />
        </li>
      </ul>
    </div>
  </section>

  <SobreMi />

  <Habilidades />

  <Proyectos />

  <Experiencia />

  <Educacion />
</Layout>

<style>
  #inicio {
    min-width: var(--min-width);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 1rem;

    overflow-x: hidden;
  }

  .inicio__container {
    animation-duration: 2s;
    animation-fill-mode: backwards;
    animation-name: right_appear;
    animation-timing-function: cubic-bezier(0.74, 0.14, 0.5, 1.73);
  }

  .social-links {
    list-style: none;
    margin: 0;

    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
  }

  .social-links li {
    margin: 0;
    padding: 0;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  span.name {
    color: var(--primary);
    animation: light 5s linear infinite;
    animation-delay: 2s;
    text-wrap: nowrap;
  }

  @keyframes light {
    0%,
    18%,
    20%,
    50.1%,
    60%,
    65.1%,
    80%,
    90.1%,
    92% {
      color: var(--primary);
      text-shadow: none;
    }

    18.1%,
    20.1%,
    30%,
    50%,
    60.1%,
    65.1%,
    80.1%,
    90%,
    92.1%,
    100% {
      color: #c9c9c9;
      text-shadow:
        0 0 10px var(--secondary),
        0 0 20px var(--secondary),
        0 0 40px var(--secondary),
        0 0 80px var(--secondary),
        0 0 160px var(--secondary);
    }
  }
</style>
